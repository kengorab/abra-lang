match foo {
  1 => 12,
  2 two => 3 + 4,
  3.4 => "5",
  5.6 f => { [6, 7] }
  true => {
    val a = 8
    a + 9
  }
  false b => ten(),
  None => {}
  None n => {}
}

val x = match foo() {
  Color.Blue => 0x0000FF,
  colors.Color.Blue => 0x0000FF,
  Color.Blue(a, b, c) => 0x0000FF,
  else f => f - 1,
}

val y = match (a, b) {
  (Foo.Bar, "asdf") t => 1,
  (None, Ok(v)) t => 2,
  (1, 2.3,) t => 3,
}

// special cases
match foo() {
  Ok(v) => v,
  Err(e) => e
}
